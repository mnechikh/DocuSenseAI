rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Tenant-scoped documents — any authenticated user can read/write
    match /tenants/{tenantId}/docs/{documentId}/{fileName} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
